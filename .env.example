# TransitFlow Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── LLM Provider ──────────────────────────────────────────────────────────────
# Choose: "ollama" (local, no key needed) or "gemini" (free API key required)
LLM_PROVIDER=ollama

# Ollama (default — runs entirely on your machine, no API key needed)
# Download: https://ollama.com/download
# Then pull the required models:
#   ollama pull llama3.2:1b        (~1.3 GB — chat model)
#   ollama pull nomic-embed-text   (~274 MB — embedding model for pgvector)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.2:1b
OLLAMA_EMBED_MODEL=nomic-embed-text

# Gemini (alternative — faster, but requires a free API key)
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── PostgreSQL (leave as-is if using Docker Compose) ─────────────────────────
PG_HOST=localhost
PG_PORT=5400
PG_USER=transitflow
PG_PASSWORD=transitflow
PG_DB=transitflow

# ── Neo4j (leave as-is if using Docker Compose) ──────────────────────────────
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=transitflow

# ── RAG tuning ────────────────────────────────────────────────────────────────
VECTOR_TOP_K=3
VECTOR_SIMILARITY_THRESHOLD=0.5
